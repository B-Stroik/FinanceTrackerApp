<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTrackerApp.Views.BudgetsPage"
             x:Name="Page"
             Title="Budgets">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Label Text="Monthly Budgets"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">

                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                    <Label Text="Month" />
                    <Entry Text="{Binding SelectedMonth}"
                           Keyboard="Numeric"
                           Placeholder="Month" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                    <Label Text="Year" />
                    <Entry Text="{Binding SelectedYear}"
                           Keyboard="Numeric"
                           Placeholder="Year" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                    <Label Text="Category" />
                    <Entry Text="{Binding Category}"
                           Placeholder="Ex: Food" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                    <Label Text="Budget Amount" />
                    <Entry Text="{Binding LimitAmount}"
                           Keyboard="Numeric"
                           Placeholder="0.00" />
                </VerticalStackLayout>
            </Grid>

            <Button Text="Save Budget"
                    Command="{Binding SaveBudgetCommand}" />

            <Button Text="Refresh Budgets"
                    Command="{Binding LoadCommand}" />

            <Label Text="{Binding Error}"
                   TextColor="Red"
                   IsVisible="{Binding Error}" />

            <Label Text="This Month's Budget List"
                   FontSize="20"
                   FontAttributes="Bold" />

            <CollectionView ItemsSource="{Binding Budgets}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Delete"
                                               Command="{Binding BindingContext.DeleteCommand, Source={x:Reference Name=Page}}"
                                               CommandParameter="{Binding}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border Margin="0,4"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 10">
                                <VerticalStackLayout Spacing="6">

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Category}"
                                               FontAttributes="Bold"
                                               FontSize="18" />

                                        <Label Grid.Column="1"
                                               Text="{Binding MonthLabel}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*,*">
                                        <VerticalStackLayout>
                                            <Label Text="Budgeted"
                                                   FontAttributes="Bold"
                                                   FontSize="12" />
                                            <Label Text="{Binding LimitAmount, StringFormat='${0:F2}'}" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="1">
                                            <Label Text="Spent"
                                                   FontAttributes="Bold"
                                                   FontSize="12" />
                                            <Label Text="{Binding Spent, StringFormat='${0:F2}'}" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="2">
                                            <Label Text="Remaining"
                                                   FontAttributes="Bold"
                                                   FontSize="12" />
                                            <Label Text="{Binding Remaining, StringFormat='${0:F2}'}" />
                                        </VerticalStackLayout>
                                    </Grid>

                                </VerticalStackLayout>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
